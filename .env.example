# Copy to .env and fill in real values. NEVER commit .env.

# --- App access ---
# Shared password for app access. Bcrypt-hashed at runtime if APP_PASSWORD_HASH unset.
APP_PASSWORD=changeme
# Optional pre-hashed password (overrides APP_PASSWORD):
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your-pw'))"
# APP_PASSWORD_HASH=

# Session signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-long-random-string

CURRENCY=INR

# --- Database ---
# Local dev default is SQLite. In production use the Supabase *pooled* URI:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./lif.db

# --- Meta (Facebook/Instagram) Ads ---
# Create a Meta app (Business), connect a Page/Instagram, generate a long-lived
# Page access token, and find your Ad Account ID (numeric, drop the "act_").
META_APP_SECRET=
META_VERIFY_TOKEN=choose-a-random-string-for-webhook-verification
META_PAGE_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_VERSION=v19.0

# --- Legacy Google Sheets (ONLY for the one-time migration script) ---
# GOOGLE_SA_JSON_PATH=
# GOOGLE_SA_JSON_BASE64=
# GOOGLE_SHEET_ID=

# --- Email (Gmail SMTP) for follow-up reminder digests ---
# Use a Gmail App Password (Google Account → Security → 2-Step Verification →
# App passwords), NOT your normal password. SMTP_FROM defaults to SMTP_USER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Absolute base URL used for links inside emails.
PUBLIC_BASE_URL=https://lifcrm.netlify.app

# --- Inbound lead capture (Google Sheet) — interim until Meta is fully live ---
# Reuses GOOGLE_SA_JSON_PATH / GOOGLE_SA_JSON_BASE64 above for auth. Share the
# sheet with the service-account email. LEADS_INTAKE_TAB is the worksheet name.
LEADS_INTAKE_SHEET_ID=
LEADS_INTAKE_TAB=Form Responses 1
